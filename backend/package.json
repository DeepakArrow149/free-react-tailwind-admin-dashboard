{
  "name": "enterprise-saas-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Multi-tenant SaaS backend with tenant resolution, JWT auth, and automatic database provisioning",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate:master": "tsx src/scripts/migrateMaster.ts",
    "seed:master": "tsx src/scripts/seedMaster.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mysql2": "^3.12.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.13.5",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2"
  }
}
