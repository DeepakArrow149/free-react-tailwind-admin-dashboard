# ─── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-key-replace-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=dev-refresh-secret-key-replace-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ─── Master Database ────────────────────────────────────────
MASTER_DB_HOST=127.0.0.1
MASTER_DB_PORT=3306
MASTER_DB_USER=root
MASTER_DB_PASSWORD=Mysql@2026
MASTER_DB_NAME=saas_master

# ─── Default Tenant DB Host ─────────────────────────────────
TENANT_DB_HOST=127.0.0.1
TENANT_DB_PORT=3306
TENANT_DB_USER=root
TENANT_DB_PASSWORD=Mysql@2026

# ─── Super Admin Seed ───────────────────────────────────────
SUPER_ADMIN_EMAIL=superadmin@system
SUPER_ADMIN_PASSWORD=Admin@123
SUPER_ADMIN_NAME=Super Admin

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
